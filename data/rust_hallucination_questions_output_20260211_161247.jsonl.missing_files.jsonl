{
  "Cargo.toml": {
    "dependencies": {
      "cms": "0.1.0",
      "der": { "version": "0.6", "features": ["alloc"] }
    }
  },
  "main.rs": {
    "code": "use cms::{content_info::ContentInfo, signed_data::SignedData};\nuse der::{Decode, asn1::ContextSpecific};\n\nfn main() {\n    let body = include_bytes!(\"ci.der\"); // Replace with your DER file\n    \n    let ci = ContentInfo::from_der(body).expect(\"Failed to parse ContentInfo\");\n    println!(\"Content Type: {}\", ci.content_type);\n    \n    let content = ci.content.expect(\"Content not present\");\n    let tagged = content.decode_as::<ContextSpecific>()\n        .expect(\"Failed to parse context-specific wrapper\");\n    assert_eq!(tagged.tag().value(), 0, \"Unexpected context tag\");\n    \n    let sd = SignedData::from_der(tagged.value())\n        .expect(\"Failed to parse SignedData\");\n    \n    println!(\"Successfully parsed SignedData version: {}\", sd.version);\n}"
  }
}
